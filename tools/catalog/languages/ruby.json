[
  {
    "id": "bundler",
    "name": "Bundler",
    "type": "cli",
    "category": ["build", "package-management"],
    "languages": ["ruby"],
    "description": "Ruby's canonical dependency manager — reads Gemfile, resolves versions, installs gems, locks Gemfile.lock",
    "when_to_use": "Every Ruby project; the foundation of Ruby dependency management",
    "install": { "command": "gem install bundler", "binary_name": "bundle" },
    "run": { "command": "bundle", "common_flags": ["install", "update", "exec <cmd>", "outdated"] },
    "risk_level": "medium",
    "requires": ["ruby"],
    "cli_support": ["claude", "gemini", "opencode", "codex"],
    "tags": ["package-manager", "dependencies", "gems"],
    "github": "https://github.com/rubygems/rubygems",
    "security": { "trust_level": "verified", "last_checked": "2026-04-03" }
  },
