    "name": "detekt",
    "type": "cli",
    "category": ["lint"],
    "languages": ["kotlin"],
    "description": "Static code analyzer for Kotlin focused on code smells, complexity, and maintainability",
    "when_to_use": "Production Kotlin codebases that need deeper quality gates than ktlint",
    "install": { "command": "brew install detekt", "binary_name": "detekt" },
    "run": { "command": "detekt", "common_flags": ["--input src/main/kotlin"] },
    "risk_level": "low",
    "cli_support": ["claude", "gemini", "opencode", "codex"],
