[
  {
    "id": "kotlinc",
    "name": "Kotlin compiler",
    "type": "cli",
    "category": ["build"],
    "languages": ["kotlin"],
    "description": "The official Kotlin command-line compiler — compiles .kt sources to JVM bytecode, JS, or native binaries",
    "when_to_use": "Base dependency for any Kotlin project; usually invoked via Gradle rather than directly",
    "install": { "command": "sdk install kotlin", "binary_name": "kotlinc" },
    "run": { "command": "kotlinc", "common_flags": ["-include-runtime", "-d out.jar"] },
    "risk_level": "low",
    "cli_support": ["claude", "gemini", "opencode", "codex"],
    "tags": ["compiler", "kotlin"],
    "github": "https://github.com/JetBrains/kotlin",
    "security": { "trust_level": "verified", "last_checked": "2026-04-03" }
  },
  {
    "id": "ktlint",
    "name": "ktlint",
    "type": "cli",
    "category": ["lint", "format"],
    "languages": ["kotlin"],
    "description": "Anti-bikeshedding Kotlin linter with built-in formatter — enforces the official Kotlin coding conventions",
    "when_to_use": "Any Kotlin project that wants automated style enforcement and formatting without configuration overhead",
    "install": { "command": "brew install ktlint", "binary_name": "ktlint" },
    "run": { "command": "ktlint", "common_flags": ["-F", "--reporter=checkstyle"] },
    "risk_level": "low",
    "cli_support": ["claude", "gemini", "opencode", "codex"],
    "tags": ["lint", "format", "style"],
    "github": "https://github.com/pinterest/ktlint",
    "security": { "trust_level": "verified", "last_checked": "2026-04-03" }
  },
  {
