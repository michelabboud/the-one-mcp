[
  {
    "id": "composer",
    "name": "Composer",
    "type": "cli",
    "category": ["build", "package-management"],
    "languages": ["php"],
    "description": "Dependency manager for PHP — reads composer.json, resolves versions, installs packages from Packagist",
    "when_to_use": "Every modern PHP project; the foundation of PHP dependency management",
    "install": { "command": "curl -sS https://getcomposer.org/installer | php", "binary_name": "composer" },
    "run": { "command": "composer", "common_flags": ["install", "update", "require <pkg>", "dump-autoload"] },
    "risk_level": "medium",
    "requires": ["php"],
    "cli_support": ["claude", "gemini", "opencode", "codex"],
    "tags": ["package-manager", "dependencies"],
    "github": "https://github.com/composer/composer",
    "security": { "trust_level": "verified", "last_checked": "2026-04-03" }
  },
