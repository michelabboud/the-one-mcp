[
  {
    "id": "composer",
    "name": "Composer",
    "type": "cli",
    "category": ["build", "package-management"],
    "languages": ["php"],
    "description": "Dependency manager for PHP — reads composer.json, resolves versions, installs packages from Packagist",
    "when_to_use": "Every modern PHP project; the foundation of PHP dependency management",
    "install": { "command": "curl -sS https://getcomposer.org/installer | php", "binary_name": "composer" },
    "run": { "command": "composer", "common_flags": ["install", "update", "require <pkg>", "dump-autoload"] },
    "risk_level": "medium",
    "requires": ["php"],
    "cli_support": ["claude", "gemini", "opencode", "codex"],
    "tags": ["package-manager", "dependencies"],
    "github": "https://github.com/composer/composer",
    "security": { "trust_level": "verified", "last_checked": "2026-04-03" }
  },
  {
    "id": "phpunit",
    "name": "PHPUnit",
    "type": "cli",
    "category": ["test"],
    "languages": ["php"],
    "description": "The de-facto unit testing framework for PHP — xUnit-style with fixtures, data providers, and mock objects",
    "when_to_use": "Default testing framework for PHP projects including Laravel and Symfony",
    "install": { "command": "composer require --dev phpunit/phpunit", "binary_name": "phpunit" },
    "run": { "command": "vendor/bin/phpunit", "common_flags": ["--testsuite Unit", "--coverage-html coverage"] },
    "risk_level": "low",
    "requires": ["php", "composer"],
    "cli_support": ["claude", "gemini", "opencode", "codex"],
    "tags": ["test", "xunit"],
    "github": "https://github.com/sebastianbergmann/phpunit",
    "security": { "trust_level": "verified", "last_checked": "2026-04-03" }
  },
  {
    "id": "phpstan",
    "name": "PHPStan",
    "type": "cli",
    "category": ["lint"],
    "languages": ["php"],
    "description": "PHP static analysis tool that discovers bugs without running the code — configurable strictness levels 0-9",
    "when_to_use": "In CI to catch type errors, undefined methods, and dead code in PHP projects",
    "install": { "command": "composer require --dev phpstan/phpstan", "binary_name": "phpstan" },
    "run": { "command": "vendor/bin/phpstan analyse", "common_flags": ["--level=max", "src tests"] },
    "risk_level": "low",
    "requires": ["php", "composer"],
    "cli_support": ["claude", "gemini", "opencode", "codex"],
    "tags": ["lint", "static-analysis", "type-checking"],
    "github": "https://github.com/phpstan/phpstan",
    "security": { "trust_level": "verified", "last_checked": "2026-04-03" }
  },
  {
    "id": "psalm",
    "name": "Psalm",
    "type": "cli",
    "category": ["lint"],
    "languages": ["php"],
    "description": "Static analysis tool for PHP from Vimeo — focuses on finding type errors and has auto-fix support",
    "when_to_use": "Alternative to PHPStan; especially strong on type inference for legacy PHP codebases",
    "install": { "command": "composer require --dev vimeo/psalm", "binary_name": "psalm" },
    "run": { "command": "vendor/bin/psalm", "common_flags": ["--show-info=true", "--alter"] },
    "risk_level": "low",
    "requires": ["php", "composer"],
    "cli_support": ["claude", "gemini", "opencode", "codex"],
    "tags": ["lint", "static-analysis"],
    "github": "https://github.com/vimeo/psalm",
    "security": { "trust_level": "verified", "last_checked": "2026-04-03" }
  },
  {
    "id": "php-cs-fixer",
    "name": "PHP CS Fixer",
    "type": "cli",
    "category": ["format"],
    "languages": ["php"],
    "description": "Fixes PHP code style to a given coding standard (PSR-1, PSR-2, PSR-12, Symfony, etc.) with safe auto-correction",
    "when_to_use": "Any PHP project that wants consistent style enforcement in editor and CI",
    "install": { "command": "composer require --dev friendsofphp/php-cs-fixer", "binary_name": "php-cs-fixer" },
    "run": { "command": "vendor/bin/php-cs-fixer fix", "common_flags": ["--dry-run", "--diff"] },
    "risk_level": "low",
    "requires": ["php", "composer"],
    "cli_support": ["claude", "gemini", "opencode", "codex"],
    "tags": ["format", "style", "psr"],
    "github": "https://github.com/PHP-CS-Fixer/PHP-CS-Fixer",
    "security": { "trust_level": "verified", "last_checked": "2026-04-03" }
  },
  {
    "id": "pest",
    "name": "Pest",
    "type": "cli",
    "category": ["test"],
    "languages": ["php"],
    "description": "Elegant PHP testing framework with a focus on simplicity — built on top of PHPUnit with a more expressive API",
    "when_to_use": "Modern PHP projects that want a cleaner testing DSL than PHPUnit",
    "install": { "command": "composer require --dev pestphp/pest", "binary_name": "pest" },
    "run": { "command": "vendor/bin/pest", "common_flags": ["--coverage", "--parallel"] },
    "risk_level": "low",
    "requires": ["php", "composer"],
    "cli_support": ["claude", "gemini", "opencode", "codex"],
    "tags": ["test"],
    "github": "https://github.com/pestphp/pest",
    "security": { "trust_level": "verified", "last_checked": "2026-04-03" }
  },
  {
    "id": "laravel-artisan",
    "name": "Laravel Artisan",
    "type": "cli",
    "category": ["build", "automation"],
    "languages": ["php"],
    "frameworks": ["laravel"],
    "description": "Laravel's command-line interface — runs migrations, clears caches, generates scaffolds, serves the app",
    "when_to_use": "Any Laravel project; the primary admin interface for Laravel applications",
    "install": { "command": "composer create-project laravel/laravel <name>", "binary_name": "artisan" },
    "run": { "command": "php artisan", "common_flags": ["serve", "migrate", "make:controller", "tinker", "queue:work"] },
    "risk_level": "low",
    "requires": ["php", "composer"],
    "cli_support": ["claude", "gemini", "opencode", "codex"],
    "tags": ["laravel", "framework", "cli"],
    "github": "https://github.com/laravel/laravel",
    "security": { "trust_level": "verified", "last_checked": "2026-04-03" }
  }
]
