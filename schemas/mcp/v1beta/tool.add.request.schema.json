{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "the-one.mcp.v1beta.tool.add.request",
  "title": "tool.add request",
  "type": "object",
  "required": ["id", "name", "description", "install_command", "run_command"],
  "properties": {
    "id": { "type": "string", "description": "Unique tool identifier" },
    "name": { "type": "string", "description": "Display name" },
    "description": { "type": "string", "description": "What this tool does" },
    "install_command": { "type": "string", "description": "Command to install the tool" },
    "run_command": { "type": "string", "description": "Command to run the tool" },
    "tool_type": { "type": "string", "description": "Tool type", "default": "cli" },
    "category": { "type": "array", "items": { "type": "string" } },
    "languages": { "type": "array", "items": { "type": "string" } },
    "tags": { "type": "array", "items": { "type": "string" } },
    "github": { "type": "string" },
    "risk_level": { "type": "string" },
    "cli": { "type": "string", "description": "Target CLI (default: all)" }
  },
  "additionalProperties": false
}
