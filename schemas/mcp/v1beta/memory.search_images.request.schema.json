{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "the-one.mcp.v1beta.memory.search_images.request",
  "title": "memory.search_images request",
  "type": "object",
  "required": ["project_root", "project_id"],
  "properties": {
    "project_root": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "query": {
      "type": "string",
      "minLength": 1,
      "description": "Natural-language text query (mutually exclusive with image_base64)"
    },
    "image_base64": {
      "type": "string",
      "description": "Base64-encoded PNG/JPEG/WebP image bytes (mutually exclusive with query)"
    },
    "top_k": {
      "type": "integer",
      "minimum": 1,
      "default": 5
    }
  },
  "additionalProperties": false
}
